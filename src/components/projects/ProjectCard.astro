---
import SurfaceCard from "@/components/ui/SurfaceCard.astro";
import StoneButton from "@/components/ui/StoneButton.astro";
import { getProjectStatusTone } from "@/lib/status";
import type { Project } from "@/types/content";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const tone = getProjectStatusTone(project.status);
---

<SurfaceCard className="lift-card h-full p-6">
  <article class="relative z-10 flex h-full flex-col gap-5">
    <div class="flex items-center justify-between gap-4">
      <span class="project-coordinate">{project.coordinate}</span>
      <span class={`rounded-full border px-3 py-1 text-xs status-${tone}`}>{project.status}</span>
    </div>

    <div>
      <h3 class="card-title">{project.title}</h3>
      <p class="card-summary">{project.summary}</p>
    </div>

    <div class="tag-list">
      {project.tech.map((item) => <span class="tag-pill">{item}</span>)}
    </div>

    <div class="mt-auto flex flex-wrap gap-3 pt-2">
      {project.links.demo && <StoneButton href={project.links.demo} label="Demo" icon="external" variant="primary" />}
      {project.links.github && <StoneButton href={project.links.github} label="GitHub" icon="github" variant="secondary" />}
      {project.links.caseStudy && <StoneButton href={project.links.caseStudy} label="Case Study" icon="arrow" variant="secondary" />}
    </div>
  </article>
</SurfaceCard>
