---
import StoneStatusBadge from "@/components/board/StoneStatusBadge.astro";
import SurfaceCard from "@/components/ui/SurfaceCard.astro";
import StoneButton from "@/components/ui/StoneButton.astro";
import { getPrimaryProductAction } from "@/lib/content";
import type { Product } from "@/types/content";

interface Props {
  product: Product;
}

const { product } = Astro.props;
const action = getPrimaryProductAction(product);
---

<SurfaceCard className="lift-card h-full p-6">
  <article class="relative z-10 flex h-full flex-col gap-5">
    <div class="flex items-start justify-between gap-4">
      <StoneStatusBadge status={product.status} />
    </div>

    <div>
      <h3 class="card-title">{product.name}</h3>
      <p class="card-summary">{product.description}</p>
    </div>

    <div class="tag-list">
      {product.category.map((item) => <span class="tag-pill">{item}</span>)}
    </div>

    {product.tech.length > 0 && (
      <p class="project-coordinate">Tech: {product.tech.join(" / ")}</p>
    )}

    <div class="mt-auto flex flex-wrap gap-3 pt-2">
      <StoneButton href={action.href} label={action.label} disabled={action.disabled} icon="external" variant="primary" />
      {product.repo && <StoneButton href={product.repo} label="Repo" icon="github" variant="secondary" />}
    </div>
  </article>
</SurfaceCard>
