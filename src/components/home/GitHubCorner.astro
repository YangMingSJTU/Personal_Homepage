---
interface Props {
  href?: string;
}

const { href = "https://github.com/YangMingSJTU/Personal_Homepage" } = Astro.props;
---

<a
  href={href}
  class="github-corner"
  data-github-corner
  data-corner-style="holographic-fold"
  aria-label="View source on GitHub"
  target="_blank"
  rel="noopener noreferrer"
>
  <span class="github-corner-halo" aria-hidden="true"></span>
  <span class="github-corner-fold" data-github-fold data-fold-state="rest" aria-hidden="true">
    <span class="github-corner-fold-edge" data-github-fold-edge></span>
    <span class="github-corner-fold-scan"></span>
    <span class="github-corner-mark">GH</span>
  </span>
</a>

<script is:inline>
  (() => {
    const setFoldState = (corner, state) => {
      corner?.querySelector("[data-github-fold]")?.setAttribute("data-fold-state", state);
    };

    const bindCorner = () => {
      document.querySelectorAll("[data-github-corner]").forEach((corner) => {
        corner.addEventListener("pointerenter", () => setFoldState(corner, "expanded"));
        corner.addEventListener("pointerleave", () => setFoldState(corner, "rest"));
        corner.addEventListener("focus", () => setFoldState(corner, "expanded"));
        corner.addEventListener("blur", () => setFoldState(corner, "rest"));
        corner.addEventListener("pointerdown", () => setFoldState(corner, "expanded"));
        corner.addEventListener("pointerup", () => setFoldState(corner, "rest"));
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", bindCorner, { once: true });
    } else {
      bindCorner();
    }
  })();
</script>
