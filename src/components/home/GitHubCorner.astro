---
interface Props {
  href?: string;
}

const { href = "https://github.com/YangMingSJTU/Personal_Homepage" } = Astro.props;
---

<a
  href={href}
  class="github-corner"
  data-github-corner
  data-corner-style="page-corner-curl"
  aria-label="View source on GitHub"
  target="_blank"
  rel="noopener noreferrer"
>
  <span class="github-corner-fold" data-github-fold data-fold-state="rest" aria-hidden="true">
    <span class="github-corner-paper" data-github-corner-paper></span>
    <span class="github-corner-curl-ridge" data-github-curl-ridge></span>
    <span class="github-corner-curl-sheet" data-github-curl-sheet>
      <svg class="github-corner-curl-art" viewBox="0 0 100 100" preserveAspectRatio="none" focusable="false">
        <defs>
          <linearGradient id="githubCornerFace" x1="12%" y1="3%" x2="92%" y2="95%">
            <stop offset="0%" stop-color="#ffffff" />
            <stop offset="28%" stop-color="#f9fbff" />
            <stop offset="62%" stop-color="#dfe7f2" />
            <stop offset="100%" stop-color="#fbfdff" />
          </linearGradient>
          <radialGradient id="githubCornerShine" cx="19%" cy="11%" r="78%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity="0.95" />
            <stop offset="55%" stop-color="#ffffff" stop-opacity="0.2" />
            <stop offset="100%" stop-color="#ffffff" stop-opacity="0" />
          </radialGradient>
        </defs>
        <path
          d="M100 0 L100 100 C86 86 72 70 55 54 C37 36 20 16 0 0 Z"
          fill="url(#githubCornerFace)"
        />
        <path
          d="M100 0 L100 100 C86 86 72 70 55 54 C37 36 20 16 0 0 Z"
          fill="url(#githubCornerShine)"
        />
      </svg>
      <svg class="github-corner-mark" data-github-corner-mark viewBox="0 0 16 16" focusable="false">
        <path
          fill="currentColor"
          d="M8 1.4a6.8 6.8 0 0 0-2.15 13.25c.34.06.47-.14.47-.32v-1.16c-1.9.41-2.3-.8-2.3-.8-.31-.79-.76-1-.76-1-.62-.43.05-.42.05-.42.69.05 1.05.7 1.05.7.61 1.04 1.6.74 1.99.56.06-.44.24-.74.43-.91-1.52-.17-3.12-.76-3.12-3.38 0-.75.27-1.36.7-1.84-.07-.17-.3-.87.07-1.82 0 0 .57-.18 1.87.7A6.46 6.46 0 0 1 8 4.73c.58 0 1.16.08 1.7.23 1.3-.88 1.87-.7 1.87-.7.37.95.14 1.65.07 1.82.44.48.7 1.09.7 1.84 0 2.63-1.6 3.2-3.13 3.37.25.21.47.63.47 1.27v1.77c0 .18.12.38.47.32A6.8 6.8 0 0 0 8 1.4Z"
        />
      </svg>
    </span>
    <span class="github-corner-curl-edge" data-github-curl-edge></span>
  </span>
</a>

<script is:inline>
  (() => {
    const setFoldState = (corner, state) => {
      corner?.querySelector("[data-github-fold]")?.setAttribute("data-fold-state", state);
    };

    const bindCorner = () => {
      document.querySelectorAll("[data-github-corner]").forEach((corner) => {
        corner.addEventListener("pointerenter", () => setFoldState(corner, "expanded"));
        corner.addEventListener("pointerleave", () => setFoldState(corner, "rest"));
        corner.addEventListener("focus", () => setFoldState(corner, "expanded"));
        corner.addEventListener("blur", () => setFoldState(corner, "rest"));
        corner.addEventListener("pointerdown", () => setFoldState(corner, "expanded"));
        corner.addEventListener("pointerup", () => setFoldState(corner, "rest"));
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", bindCorner, { once: true });
    } else {
      bindCorner();
    }
  })();
</script>
