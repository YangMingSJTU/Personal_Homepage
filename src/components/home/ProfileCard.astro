---
import type { Profile } from "@/types/content";
import { withBase } from "@/lib/sitePath";

interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
const title = profile.displayTitle || "Personal Homepage";
const signature = profile.signature || "Projects / About";
const links = profile.links?.length
  ? profile.links.filter((link) => link.label !== "GitHub")
  : [
      { label: "Projects", href: "/projects" },
      { label: "About", href: "/about" }
    ];
---

<section class="profile-card" data-profile-card aria-label="个人主页入口">
  <div class="profile-card-inner fade in">
    <header>
      {
        profile.avatar?.src ? (
          <img class="profile-avatar" src={withBase(profile.avatar.src)} width="112" height="112" alt={profile.avatar.alt || title} />
        ) : (
          <div class="profile-avatar profile-avatar-fallback" aria-hidden="true">
            <span></span>
          </div>
        )
      }
      <h1>{title}</h1>
      <p>{signature}</p>
    </header>

    <nav aria-label="Profile navigation">
      <ul>
        {
          links.map((link) => (
            <li>
              <a href={withBase(link.href)} target={link.external ? "_blank" : undefined} rel={link.external ? "noopener noreferrer" : undefined}>
                <span>{link.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</section>
