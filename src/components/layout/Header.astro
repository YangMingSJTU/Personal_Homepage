---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/contact", label: "Contact" }
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isHome = currentPath === "/";
---

{
  !isHome && (
    <header class="site-header">
      <nav class="content-wrap site-nav" aria-label="Primary">
        <a href="/" class="site-logo" aria-label="Homepage">
          <span class="site-logo-stone"></span>
        </a>

        <div class="nav-pill">
          {navItems.map((item) => {
            const normalized = item.href === "/" ? "/" : item.href;
            const active = currentPath === normalized;

            return (
              <a
                href={item.href}
                class:list={[
                  "nav-link",
                  active && "nav-link-active"
                ]}
                aria-current={active ? "page" : undefined}
              >
                {item.label}
              </a>
            );
          })}
        </div>

        <div class="mobile-nav" aria-label="Mobile navigation">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="mobile-nav-link"
            >
              {item.label}
            </a>
          ))}
        </div>
      </nav>
    </header>
  )
}
