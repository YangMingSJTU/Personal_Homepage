---
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import { withBase } from "@/lib/sitePath";
import "../../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  showFooter?: boolean;
  lockViewport?: boolean;
}

const {
  title = "个人主页",
  description = "个人产品、项目和联系方式入口。",
  showFooter = true,
  lockViewport = false
} = Astro.props;

const canonical = new URL(withBase(Astro.url.pathname), Astro.site || "https://yangmingsjtu.github.io");
const ogImage = new URL(withBase("/og-image.svg"), canonical).toString();
---

<!doctype html>
<html lang="zh-CN" data-ui-theme="soft-dark" class={lockViewport ? "viewport-locked" : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <Header />
      <main>
        <slot />
      </main>
      {showFooter && <Footer />}
    </div>
  </body>
</html>
