---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="section-header">
  {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
  <h2 class="section-title">{title}</h2>
  {description && <p class="section-description">{description}</p>}
</div>
