---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mb-9 max-w-2xl">
  {eyebrow && <p class="mb-3 font-mono text-xs uppercase tracking-normal text-cyan">{eyebrow}</p>}
  <h2 class="font-display text-3xl font-semibold tracking-normal text-white sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-7 text-slate-300">{description}</p>}
</div>
