---
interface Props {
  href?: string;
  label: string;
  variant?: "primary" | "secondary" | "ghost";
  icon?: "arrow" | "external" | "github" | "mail" | "copy";
  disabled?: boolean;
  target?: string;
}

const { href, label, variant = "secondary", icon = "arrow", disabled = false, target } = Astro.props;

const classes = [
  `stone-button stone-button-${variant}`,
  "group relative inline-flex min-h-11 items-center justify-center gap-2 overflow-hidden rounded-full border px-5 py-2.5 text-sm font-semibold transition focus:outline-none focus:ring-2 focus:ring-cyan/70",
  variant === "primary" && "border-cyan/50 bg-cyan/10 text-white shadow-glow hover:bg-cyan/20",
  variant === "secondary" && "border-white/20 bg-white/[0.04] text-slate-100 hover:border-cyan/30 hover:bg-white/[0.07]",
  variant === "ghost" && "border-transparent bg-transparent text-slate-300 hover:bg-white/[0.06]",
  disabled && "pointer-events-none cursor-not-allowed opacity-50"
]
  .filter(Boolean)
  .join(" ");

const iconGlyph = {
  arrow: "->",
  external: "↗",
  github: "GH",
  mail: "@",
  copy: "CP"
}[icon];
---

{
  href && !disabled ? (
    <a href={href} target={target ?? (href.startsWith("http") ? "_blank" : undefined)} rel={href.startsWith("http") ? "noreferrer" : undefined} class={classes}>
      <span class="absolute left-3 h-2 w-2 rounded-full bg-stone/80 transition group-hover:scale-[2.8] group-hover:bg-cyan/25"></span>
      <span class="relative ml-2">{label}</span>
      <span class="relative font-mono text-xs text-cyan" aria-hidden="true">{iconGlyph}</span>
    </a>
  ) : (
    <button class={classes} disabled={disabled} type="button">
      <span class="absolute left-3 h-2 w-2 rounded-full bg-stone/70"></span>
      <span class="relative ml-2">{label}</span>
      <span class="relative font-mono text-xs text-cyan" aria-hidden="true">{iconGlyph}</span>
    </button>
  )
}
