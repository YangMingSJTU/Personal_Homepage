---
import SciFiGoBackground from "@/components/board/SciFiGoBackground.astro";
import SiteLayout from "@/components/layout/SiteLayout.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import StoneButton from "@/components/ui/StoneButton.astro";
import profileData from "@/data/profile.json";
import type { Profile } from "@/types/content";

const profile = profileData as Profile;
---

<SiteLayout title="About | 个人主页" description={profile.bio}>
  <section class="section-band relative">
    <SciFiGoBackground intensity="low" />
    <div class="content-wrap relative z-10 page-grid page-grid-two">
      <div class="surface-card p-7">
        <p class="meta-label">Profile</p>
        <h1 class="content-title-main">{profile.name}</h1>
        <p class="body-copy mt-6 text-sm">{profile.bio}</p>
        <div class="mt-7">
          <StoneButton href="/contact" label="Contact" icon="mail" variant="primary" />
        </div>
      </div>

      <div>
        <SectionHeader eyebrow="About" title="Building small, useful AI products." description="我把学习、实验和产品构建放在同一个系统里，用清晰结构推进长期成长。" />

        <div class="space-y-8">
          <section>
            <h2 class="card-title">Now</h2>
            <div class="mt-4 grid gap-3 sm:grid-cols-2">
              {profile.focus.map((item) => <div class="info-tile"><span class="info-dot"></span>{item}</div>)}
            </div>
          </section>

          <section>
            <h2 class="card-title">Skills</h2>
            <div class="tag-list mt-4">
              {profile.skills.map((item) => <span class="tag-pill">{item}</span>)}
            </div>
          </section>

          <section>
            <h2 class="card-title">Principles</h2>
            <div class="mt-4 grid gap-3">
              {profile.principles.map((item) => <p class="principle-line">{item}</p>)}
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
