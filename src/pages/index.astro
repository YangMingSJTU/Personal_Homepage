---
import IntroOpeningHero from "@/components/hero/IntroOpeningHero";
import GitHubCorner from "@/components/home/GitHubCorner.astro";
import InteractiveGoBackground from "@/components/home/InteractiveGoBackground";
import ProfileCard from "@/components/home/ProfileCard.astro";
import SiteLayout from "@/components/layout/SiteLayout.astro";
import profileData from "@/data/profile.json";
import type { Profile } from "@/types/content";

const profile = profileData as Profile;
---

<SiteLayout title="个人主页" description="项目、关于与联系方式入口。">
  <GitHubCorner href={profile.socials.github || "https://github.com/YangMingSJTU/Personal_Homepage"} />
  <IntroOpeningHero client:load />

  <section id="main-view" class="home-main content content-main relative">
    <InteractiveGoBackground client:load />
    <ProfileCard profile={profile} />
  </section>
</SiteLayout>
