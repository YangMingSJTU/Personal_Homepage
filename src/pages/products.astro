---
import SciFiGoBackground from "@/components/board/SciFiGoBackground.astro";
import SiteLayout from "@/components/layout/SiteLayout.astro";
import ProductCard from "@/components/products/ProductCard.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import productsData from "@/data/products.json";
import type { Product } from "@/types/content";

const products = productsData as Product[];
---

<SiteLayout title="Products | 个人主页" description="产品入口。">
  <section class="section-band relative">
    <SciFiGoBackground intensity="medium" />
    <div class="content-wrap relative z-10">
      <SectionHeader title="Products" />
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {products.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>
</SiteLayout>
