---
import SciFiGoBackground from "@/components/board/SciFiGoBackground.astro";
import CopyEmailButton from "@/components/contact/CopyEmailButton";
import SiteLayout from "@/components/layout/SiteLayout.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import StoneButton from "@/components/ui/StoneButton.astro";
import profileData from "@/data/profile.json";
import type { Profile } from "@/types/content";

const profile = profileData as Profile;
---

<SiteLayout title="Contact | 个人主页" description="联系方式。">
  <section class="section-band relative min-h-[calc(100vh-12rem)]">
    <SciFiGoBackground intensity="low" />
    <div class="content-wrap relative z-10 grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <SectionHeader title="Contact" />

      <div class="scifi-card p-7">
        <div class="space-y-6">
          <div>
            <p class="font-mono text-xs uppercase tracking-normal text-cyan">Email</p>
            <p class="mt-3 break-all font-display text-2xl font-semibold text-white">{profile.email}</p>
          </div>

          <div class="flex flex-wrap gap-3">
            <CopyEmailButton email={profile.email} client:load />
            {profile.socials.github && <StoneButton href={profile.socials.github} label="GitHub" icon="github" variant="secondary" />}
            {profile.socials.x && <StoneButton href={profile.socials.x} label="X / Twitter" icon="external" variant="secondary" />}
          </div>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
